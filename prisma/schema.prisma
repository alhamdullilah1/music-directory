generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Song {
  id           Int          @id @default(autoincrement())
  title        String
  artist       String
  genre        String
  scale        String?
  audioUrl     String
  imageUrl     String?
  paletteTheme String
  chords       ChordEvent[]
  gears        GearEvent[]
  lyrics       LyricEvent[]
  history      PlayHistory[]
}

model ChordEvent {
  id        Int    @id @default(autoincrement())
  songId    Int
  timestamp Float
  chordName String
  song      Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model GearEvent {
  id        Int     @id @default(autoincrement())
  songId    Int
  timestamp Float
  guitar    String
  pedal     String
  amp       String
  imageUrl  String?
  song      Song    @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model LyricEvent {
  id        Int    @id @default(autoincrement())
  songId    Int
  timestamp Float
  text      String
  song      Song   @relation(fields: [songId], references: [id], onDelete: Cascade)
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  history   PlayHistory[]
}

model PlayHistory {
  id        Int      @id @default(autoincrement())
  userId    Int
  songId    Int
  playedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
}
